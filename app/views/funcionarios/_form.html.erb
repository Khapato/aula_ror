<div class="col-12">
<%= form_with(model: funcionario) do |form| %>
  <% if funcionario.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(funcionario.errors.count, "error") %> prohibited this funcionario from being saved:</h2>

      <ul>
        <% funcionario.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
<div class="row">
    <div class="col-12">
     <%= form.label :nome, style: "display: block" %>
     <%= form.text_field :nome, class: "form-control" %>
    </div>
     <div class="col-6">
        <%= form.label :matricula, style: "display: block" %>
        <%= form.text_field :matricula, class: "form-control" %>
     </div>
     <div class="col-6">
    <%= form.label :função, style: "display: block" %>
    <%= form.select :funcao, options_for_select(["Funcionário", "Aluno"]), {include_blank: "Escolha aqui..."}, class: "form-control" %>
  </div>
</div>

<div class="row">
	<div class="col-12" style="text-align:center; margin-top:10px">
	    <%= form.submit "Enviar", class: "btn btn-danger caixa-sombra"%>
        </div>

  

  
<% end %>
</div>
